{
	"schemaVersion": 1,
	"id": "enchantment_workbench",
	"version": "${version}",
	"name": "Enchantments Enhanced",
	"description": "Reworks the vanilla enchanting table into a deterministic enchantment workbench.",
	"authors": [
		"hmed"
	],
	"contact": {
		"homepage": "https://github.com/hmedopen/enchantments-enhanced",
		"sources": "https://github.com/hmedopen/enchantments-enhanced",
		"issues": "https://github.com/hmedopen/enchantments-enhanced/issues"
	},
	"license": "MIT",
	"icon": "assets/enchantment_workbench/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.hmed.enchantmentworkbench.EnchantmentWorkbenchMod"
		],
		"client": [
			"com.hmed.enchantmentworkbench.client.EnchantmentWorkbenchClient"
		]
	},
	"mixins": [
		"enchantment_workbench.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
